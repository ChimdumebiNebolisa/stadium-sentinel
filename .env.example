# Client feature flags (NEXT_PUBLIC_* are inlined at build time)
NEXT_PUBLIC_REAL_DEMO_FLOW=false
NEXT_PUBLIC_SHOW_VENUE_ORIENTATION=false
NEXT_PUBLIC_ENABLE_ELASTIC_PULL=true
NEXT_PUBLIC_ENABLE_SENTINEL_AGENT=true
# Set true on deployed real demo for voice-first Sentinel; false keeps mock voice for CI.
NEXT_PUBLIC_ENABLE_SENTINEL_VOICE=false
NEXT_PUBLIC_SHOW_RADIO_TRANSCRIPT=false

AGENT_BACKEND_ENABLED=false
ELASTICSEARCH_URL=
ELASTICSEARCH_API_KEY=
ELASTICSEARCH_PLAYBOOKS_INDEX=stadium_playbooks
ELASTICSEARCH_LOCATIONS_INDEX=stadium_locations
ELASTICSEARCH_INCIDENT_EXAMPLES_INDEX=stadium_incident_examples
ELASTICSEARCH_EVIDENCE_INDEX=stadium_evidence
ELASTICSEARCH_ACTIVE_INCIDENTS_INDEX=stadium_active_incidents
ELASTICSEARCH_GUEST_ASSISTANCE_INDEX=stadium_guest_assistance
ELASTICSEARCH_FACILITY_STATUS_INDEX=stadium_facility_status
ELASTICSEARCH_GATE_FLOW_LOGS_INDEX=stadium_gate_flow_logs
ELASTICSEARCH_STAFF_ROSTER_INDEX=stadium_staff_roster
ELASTICSEARCH_POLICIES_INDEX=stadium_policies
ELASTICSEARCH_RADIO_TRANSCRIPTS_INDEX=stadium_radio_transcripts
ELASTICSEARCH_DISPATCH_TIMELINE_INDEX=stadium_dispatch_timeline
ELASTICSEARCH_INCIDENT_MEMORY_INDEX=stadium_incident_memory
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=
VERTEX_MODEL=gemini-2.5-flash
GOOGLE_APPLICATION_CREDENTIALS=

# Legacy compatibility aliases. Prefer the canonical variables above.
ELASTIC_API_KEY=
GEMINI_MODEL=
